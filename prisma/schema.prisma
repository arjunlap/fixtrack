generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @unique
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services  Service[]
}

model Technician {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  role      String   @default("Teknisi")
  status    String   @default("Aktif")
  qcRate    Int      @default(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id            Int      @id @default(autoincrement())

  invoice       String   @unique
  status        String   @default("ANTRI")

  customerId    Int?
  customer      Customer? @relation(fields: [customerId], references: [id])

  customerName  String
  customerPhone String
  address       String?

  countryCode   String   @default("+62")
  currency      String   @default("IDR")

  brand         String
  device        String
  imei          String?
  color         String?

  issue         String
  diagnosis     String?

  cost          Float    @default(0)

  technician    String?

  lockPattern   String?

  trackingCode  String?  @unique

  statusLogs    ServiceStatusLog[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ServiceStatusLog {
  id        Int      @id @default(autoincrement())
  serviceId Int
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  status    String
  note      String?
  createdAt DateTime @default(now())
}

model Part {
  id        Int      @id @default(autoincrement())
  name      String
  category  String
  supplier  String?
  buyPrice  Float    @default(0)
  sellPrice Float    @default(0)
  stock     Int      @default(0)
  minStock  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
